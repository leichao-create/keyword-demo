# Railway Milvus
MILVUS_RAILWAY_ADDRESS=grpc-reverse-proxy-production-7da1.up.railway.app:443

# Zilliz Cloud Milvus
MILVUS_ZILLIZ_ADDRESS=in03-4751ecda463a927.serverless.gcp-us-west1.cloud.zilliz.com:443
MILVUS_ZILLIZ_USERNAME=
MILVUS_ZILLIZ_PASSWORD=

# AIHubMix
AIHUBMIX_API_KEY=
AIHUBMIX_MODEL=gemini-2.5-pro-exp-03-25

# 向量搜索配置
# 用于生成稠密向量的 Embedding 模型（需与数据库中向量使用的模型一致）
# 常见：text-embedding-3-small(1536维) | text-embedding-3-large(3072维) | text-embedding-ada-002(1536维)
EMBEDDING_MODEL=text-embedding-3-small

# Milvus Collection 名称（默认 easykol_influencer_v1）
MILVUS_COLLECTION=easykol_influencer_v1

# 服务端口（默认 3000）
PORT=3000
